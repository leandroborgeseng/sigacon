# Banco de dados PostgreSQL
DATABASE_URL="postgresql://usuario:senha@localhost:5432/sigacon?schema=public"

# Sessão (gerar com: openssl rand -base64 32)
SESSION_SECRET="altere-este-secret-em-producao-min-32-chars"

# Porta (Railway define PORT automaticamente)
PORT=3000

# Opcional: URL base da aplicação (para links em emails etc.)
NEXT_PUBLIC_APP_URL="http://localhost:3000"

# Opcional: integração GLPI (GET /api/integracao/glpi/ticket?id=)
# GLPI_URL="https://glpi.suaempresa.com/apirest.php"
# GLPI_APP_TOKEN="..."
# GLPI_USER_TOKEN="..."
