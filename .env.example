# Banco de dados PostgreSQL
DATABASE_URL="postgresql://usuario:senha@localhost:5432/lex?schema=public"

# Railway / Docker: P3005 é tratado automaticamente no docker-start.sh (baseline).
# Só use se precisar forçar baseline quando o erro não for P3005: PRISMA_BASELINE_NON_EMPTY_DB=1
# PRISMA_BASELINE_NON_EMPTY_DB=1

# Sessão (gerar com: openssl rand -base64 32)
SESSION_SECRET="altere-este-secret-em-producao-min-32-chars"

# Porta (Railway define PORT automaticamente)
PORT=3000

# URL base da aplicação (obrigatória em produção para links no e-mail de redefinição de senha)
NEXT_PUBLIC_APP_URL="http://localhost:3000"

# Resend — envio de e-mail (redefinição de senha). Crie a chave em https://resend.com/api-keys
# Domínio do "from" deve estar verificado em Resend → Domains (SPF/DKIM).
RESEND_API_KEY="re_xxxxxxxx"
# Ex.: LeX <noreply@seudominio.com> ou onboarding@resend.dev (apenas testes)
RESEND_FROM="LeX <onboarding@resend.dev>"

# Opcional: integração GLPI (fallback se não houver registro em Configuração GLPI na aplicação)
# GLPI_URL="https://glpi.suaempresa.com/api.php/v1"
# ou …/apirest.php ou …/api (se Apache/Nginx reescrever para apirest.php, ver doc GLPI REST API)
# Se o HTTPS do GLPI usar certificado não reconhecido pelo Node (erro "fetch failed" no teste), use:
# GLPI_TLS_INSECURE=1
# Railway vs curl local: priorizar IPv4 no Node (alguns GLPI só respondem IPv4 para o provedor cloud)
# GLPI_FORCE_IPV4=1
# Tempo máximo por tentativa de initSession em ms (default 22000). Antes havia um único timer para todas as tentativas.
# GLPI_INIT_ATTEMPT_TIMEOUT_MS=22000
# GLPI_APP_TOKEN="..."
# GLPI_USER_TOKEN="..."
# Campo de busca “grupo técnico atribuído” em Ticket (search) — também configurável no banco
# GLPI_CAMPO_GRUPO_TECNICO=71
# Campo de busca “data de modificação” em Ticket (search) para sync incremental
# GLPI_CAMPO_DATA_MODIFICACAO=15
# Critérios adicionais de busca no /search/Ticket (JSON array), ex:
# GLPI_SYNC_CRITERIA_EXTRA='[{"field":12,"searchtype":"notequals","value":"6","link":"AND"}]'
# Segredo opcional para sincronização automática (cron externo chamando POST /api/integracao/glpi/sync)
# GLPI_SYNC_SECRET="troque-por-um-segredo-forte"
# Retries do sync automático por contrato (default: 2)
# GLPI_SYNC_MAX_RETRIES=2
# Mapeamento status GLPI -> coluna Kanban (JSON), ex:
# GLPI_KANBAN_MAP='{"statusToColuna":{"1":"BACKLOG","2":"EM_ANDAMENTO","4":"AGUARDANDO","5":"RESOLVIDO","6":"FECHADO"},"colunaToStatus":{"BACKLOG":1,"EM_ANDAMENTO":2,"AGUARDANDO":4,"RESOLVIDO":5,"FECHADO":6}}'
